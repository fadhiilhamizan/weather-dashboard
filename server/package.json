{
  "name": "atmosfer-server",
  "version": "1.0.0",
  "description": "Backend proxy for the Atmosfer weather dashboard. Hides the API key, normalises provider data, caches responses, and rate-limits clients.",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
