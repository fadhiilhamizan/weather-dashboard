# ---------------------------------------------------------------------------
# Atmosfer — server configuration
# Copy this file to `.env` and fill in your values. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# The port the proxy listens on.
PORT=5050

# Comma-separated list of origins allowed to call this API (the frontend).
# During local dev Vite serves on 5173. Add your deployed frontend URL too.
CORS_ORIGIN=http://localhost:5173

# --- Weather provider --------------------------------------------------------
# By DEFAULT the server uses Open-Meteo (https://open-meteo.com), which is free
# and needs NO API key or registration — so the dashboard shows real, live
# weather with zero setup.
#
# Optionally force a provider:
#   WEATHER_PROVIDER=openmeteo    # keyless, default
#   WEATHER_PROVIDER=openweather  # requires OPENWEATHER_API_KEY below
#   WEATHER_PROVIDER=demo         # offline mock data, no network calls
# Leave blank to auto-select: OpenWeather if a key is set, else Open-Meteo.
WEATHER_PROVIDER=

# Only needed if you want to use OpenWeather One Call API 3.0 instead of
# Open-Meteo. Get a free key at https://openweathermap.org/api.
OPENWEATHER_API_KEY=

# How long (in seconds) a cached weather response stays fresh. The brief asks
# for 15 minutes; that is the default.
CACHE_TTL_SECONDS=900

# How long geocoding results are cached. City coordinates basically never
# change, so we keep these much longer (24h).
GEOCODE_CACHE_TTL_SECONDS=86400

# --- Rate limiting -----------------------------------------------------------
# Simple per-IP limiter to protect your API quota from abuse / refresh storms.
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
