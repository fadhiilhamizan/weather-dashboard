# ---------------------------------------------------------------------------
# Atmosfer — client configuration
# In local development you can leave this empty: Vite proxies /api to the
# backend automatically (see vite.config.js).
#
# In production (e.g. the frontend on Vercel, the API on Render) set this to
# your deployed API origin, WITHOUT a trailing slash:
#   VITE_API_BASE_URL=https://atmosfer-api.onrender.com
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=
